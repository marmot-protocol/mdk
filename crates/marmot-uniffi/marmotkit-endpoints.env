# Build-time MarmotKit service endpoint defaults.
#
# These URLs are public routing configuration, not credentials. Host apps still
# supply bearer tokens at runtime. Callers may override either value in the
# environment before invoking a binding build script.

: "${MARMOT_AUDIT_LOG_TRACKER_ENDPOINT:=https://goggles.ipf.dev/api/v1/audit-logs/}"
: "${MARMOT_RELAY_TELEMETRY_OTLP_ENDPOINT:=https://otlp.ipf.dev/v1/metrics}"

export MARMOT_AUDIT_LOG_TRACKER_ENDPOINT
export MARMOT_RELAY_TELEMETRY_OTLP_ENDPOINT
