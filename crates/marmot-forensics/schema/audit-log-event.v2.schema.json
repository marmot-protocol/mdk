{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.marmot.dev/forensics/audit-log-event.v2.schema.json",
  "title": "Marmot forensic audit log event v2",
  "description": "Schema for one line in a Marmot append-only forensic audit JSONL file. Version 2 adds explicit audit data modes, transport wire evidence, recipient expectations, decoded full-data message content, and convergence decision traces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "seq", "wall_time_ms", "audit_data_mode", "engine_id", "kind"],
  "properties": {
    "schema_version": {
      "const": "marmot-forensics-audit/v2"
    },
    "seq": {
      "$ref": "#/$defs/u64"
    },
    "wall_time_ms": {
      "$ref": "#/$defs/u64"
    },
    "recorder_session_id": {
      "type": "string",
      "minLength": 1
    },
    "audit_data_mode": {
      "$ref": "#/$defs/auditDataMode"
    },
    "account_ref": {
      "$ref": "#/$defs/refHex16"
    },
    "engine_id": {
      "type": "string",
      "minLength": 1
    },
    "group_ref": {
      "$ref": "#/$defs/hexString"
    },
    "context": {
      "$ref": "#/$defs/auditEventContext"
    },
    "kind": {
      "$ref": "#/$defs/auditEventKind"
    }
  },
  "$defs": {
    "u64": {
      "type": "integer",
      "minimum": 0
    },
    "u16": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "hexString": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$"
    },
    "refHex16": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{32}$"
    },
    "digestHex": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{64}$"
    },
    "messageId": {
      "description": "Canonical Marmot message artifact id. For MLS content-bearing artifacts this is the SHA-256 digest of the MLS content bytes. Transport and on-wire ids must be recorded in transportWireEnvelope instead of overloading msg_id.",
      "$ref": "#/$defs/digestHex"
    },
    "pubkeyHex": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{64}$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "messageRefArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/messageId"
      }
    },
    "auditDataMode": {
      "enum": ["obfuscated_sensitive_data", "full_data"]
    },
    "auditEventContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operation_id": {
          "type": "string"
        },
        "human_action": {
          "$ref": "#/$defs/auditHumanActionContext"
        },
        "transport": {
          "$ref": "#/$defs/auditTransportContext"
        },
        "engine": {
          "$ref": "#/$defs/auditEngineContext"
        },
        "group": {
          "$ref": "#/$defs/auditGroupContext"
        },
        "convergence": {
          "$ref": "#/$defs/auditConvergenceContext"
        },
        "source": {
          "$ref": "#/$defs/auditSourceContext"
        }
      }
    },
    "auditHumanActionContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "origin"],
      "properties": {
        "action": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "fields": {
          "$ref": "#/$defs/stringArray"
        },
        "component_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/u16"
          }
        },
        "target_count": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "auditTransportContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport_source"],
      "properties": {
        "transport_source": {
          "type": "string"
        },
        "delivery_plane": {
          "type": "string"
        },
        "relay_url": {
          "type": "string"
        },
        "subscription_id": {
          "type": "string"
        },
        "wire": {
          "$ref": "#/$defs/transportWireEnvelope"
        }
      }
    },
    "auditEngineContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ciphersuite": {
          "$ref": "#/$defs/u16"
        },
        "max_past_epochs": {
          "$ref": "#/$defs/u64"
        },
        "convergence_max_rewind_commits": {
          "$ref": "#/$defs/u64"
        },
        "supported_app_component_count": {
          "$ref": "#/$defs/u64"
        },
        "feature_count": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "auditGroupContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "epoch": {
          "$ref": "#/$defs/u64"
        },
        "member_count": {
          "$ref": "#/$defs/u64"
        },
        "required_app_component_count": {
          "$ref": "#/$defs/u64"
        },
        "admin_count": {
          "$ref": "#/$defs/u64"
        },
        "convergence_max_rewind_commits": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "auditConvergenceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "$ref": "#/$defs/convergencePhase"
        },
        "inferred": {
          "type": "boolean"
        }
      }
    },
    "auditSourceContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account_label": {
          "type": "string"
        },
        "device_label": {
          "type": "string"
        },
        "device_id": {
          "type": "string"
        },
        "device_name": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "app_version": {
          "type": "string"
        },
        "upload_trigger": {
          "type": "string"
        },
        "account_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "account_npub": {
          "type": "string"
        }
      }
    },
    "transportWireEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transport": {
          "type": "string"
        },
        "delivery_plane": {
          "type": "string"
        },
        "wire_id": {
          "type": "string"
        },
        "wire_kind": {
          "type": "string"
        },
        "wire_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "transport_group_id": {
          "type": "string"
        },
        "relay_url": {
          "type": "string"
        },
        "subscription_id": {
          "type": "string"
        },
        "nostr_event_id": {
          "$ref": "#/$defs/digestHex"
        },
        "nostr_kind": {
          "$ref": "#/$defs/u64"
        },
        "nostr_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "gift_wrap_event_id": {
          "$ref": "#/$defs/digestHex"
        },
        "welcome_nostr_event_id": {
          "description": "Outer Nostr event id for a transport-level welcome envelope, when the welcome is carried as a Nostr event.",
          "$ref": "#/$defs/digestHex"
        },
        "welcome_rumor_event_id": {
          "description": "Inner Nostr rumor event id for a gift-wrapped welcome, when available after unwrapping.",
          "$ref": "#/$defs/digestHex"
        },
        "welcome_key_package_tag": {
          "description": "KeyPackage e-tag or equivalent welcome target tag that links the welcome to the added member/key package.",
          "type": "string"
        },
        "publish_result_id": {
          "type": "string"
        }
      }
    },
    "messageArtifactKind": {
      "enum": ["application_message", "commit", "proposal", "welcome", "group_info", "unknown"]
    },
    "recipientScope": {
      "enum": [
        "all_current_group_members",
        "all_other_current_group_members",
        "added_member_only",
        "explicit_members",
        "self_only",
        "unknown"
      ]
    },
    "recipientExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_kind", "recipient_scope"],
      "properties": {
        "artifact_kind": {
          "$ref": "#/$defs/messageArtifactKind"
        },
        "recipient_scope": {
          "$ref": "#/$defs/recipientScope"
        },
        "membership_epoch": {
          "$ref": "#/$defs/u64"
        },
        "basis_commit_id": {
          "$ref": "#/$defs/messageId"
        },
        "expected_member_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/refHex16"
          }
        },
        "expected_pubkeys_hex": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pubkeyHex"
          }
        },
        "expected_count": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "outboundMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["msg_id", "artifact_kind"],
      "properties": {
        "msg_id": {
          "$ref": "#/$defs/messageId"
        },
        "artifact_kind": {
          "$ref": "#/$defs/messageArtifactKind"
        },
        "transport": {
          "$ref": "#/$defs/transportWireEnvelope"
        },
        "recipient_expectation": {
          "$ref": "#/$defs/recipientExpectation"
        }
      }
    },
    "decodedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_type"],
      "properties": {
        "content_type": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "json": {
          "$ref": "#/$defs/jsonValue"
        },
        "bytes_b64": {
          "type": "string"
        }
      }
    },
    "decodedApplicationEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/u64"
        },
        "content": {
          "type": "string"
        },
        "pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "created_at_ms": {
          "$ref": "#/$defs/u64"
        },
        "client_message_id": {
          "type": "string"
        },
        "reply_to_message_id": {
          "type": "string"
        },
        "thread_root_message_id": {
          "type": "string"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachmentMetadata"
          }
        },
        "raw": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "messageAuthor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "member_ref": {
          "$ref": "#/$defs/refHex16"
        },
        "member_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "account_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "npub": {
          "type": "string"
        }
      }
    },
    "attachmentMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "component_id": {
          "$ref": "#/$defs/u16"
        },
        "content_type": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "byte_len": {
          "$ref": "#/$defs/u64"
        },
        "digest": {
          "$ref": "#/$defs/digestHex"
        },
        "metadata": {
          "$ref": "#/$defs/jsonObject"
        }
      }
    },
    "groupStateChangeKind": {
      "enum": [
        "member_added",
        "member_removed",
        "member_left",
        "admin_added",
        "admin_removed",
        "group_renamed",
        "topic_changed",
        "group_avatar_changed",
        "message_retention_changed"
      ]
    },
    "membershipChangeSource": {
      "description": "Explains membership-removal attribution when change_kind alone is not enough. For example, member_removed with admin_action and an actor is an admin removal; member_removed with convergence and no actor is a convergence-resolved departure that must not be rendered as an admin action.",
      "enum": ["self_leave", "admin_action", "convergence", "remote_commit", "unknown"]
    },
    "groupStateValue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "digest": {
          "$ref": "#/$defs/digestHex"
        },
        "len": {
          "$ref": "#/$defs/u64"
        },
        "text": {
          "type": "string"
        },
        "json": {
          "$ref": "#/$defs/jsonValue"
        },
        "pubkeys_hex": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pubkeyHex"
          }
        }
      }
    },
    "convergencePhase": {
      "enum": ["started", "waiting", "evaluating", "selected", "blocked", "applied", "failed", "stable", "unrecoverable"]
    },
    "convergenceCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch_id", "fork_epoch", "tip_epoch"],
      "properties": {
        "branch_id": {
          "type": "string"
        },
        "fork_epoch": {
          "$ref": "#/$defs/u64"
        },
        "tip_epoch": {
          "$ref": "#/$defs/u64"
        },
        "commit_ids": {
          "$ref": "#/$defs/messageRefArray"
        },
        "commit_count": {
          "$ref": "#/$defs/u64"
        },
        "state_digest": {
          "$ref": "#/$defs/digestHex"
        },
        "tip_digest": {
          "$ref": "#/$defs/digestHex"
        },
        "tip_priority": {
          "type": "string"
        },
        "tip_committer_ref": {
          "$ref": "#/$defs/refHex16"
        },
        "tip_committer_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "retained_anchor_status": {
          "type": "string"
        },
        "last_input_time_ms": {
          "$ref": "#/$defs/u64"
        },
        "eligible": {
          "type": "boolean"
        },
        "rejection_reasons": {
          "$ref": "#/$defs/stringArray"
        },
        "score": {
          "$ref": "#/$defs/convergenceScore"
        },
        "app_witnesses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/appWitness"
          }
        }
      }
    },
    "convergenceScore": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valid_commit_depth": {
          "$ref": "#/$defs/u64"
        },
        "effective_commit_depth": {
          "$ref": "#/$defs/u64"
        },
        "witness_quorum_met": {
          "type": "boolean"
        },
        "app_witness_score": {
          "$ref": "#/$defs/u64"
        },
        "tip_priority": {
          "type": "string"
        },
        "tip_committer_ref": {
          "$ref": "#/$defs/refHex16"
        },
        "tip_committer_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        },
        "tip_digest": {
          "$ref": "#/$defs/digestHex"
        }
      }
    },
    "appWitness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["epoch"],
      "properties": {
        "epoch": {
          "$ref": "#/$defs/u64"
        },
        "sender_ref": {
          "$ref": "#/$defs/refHex16"
        },
        "sender_pubkey_hex": {
          "$ref": "#/$defs/pubkeyHex"
        }
      }
    },
    "convergenceRuleEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_name", "result"],
      "properties": {
        "rule_name": {
          "type": "string"
        },
        "scope": {
          "enum": ["run", "candidate", "candidate_pair"]
        },
        "candidate_branch_id": {
          "type": "string"
        },
        "other_candidate_branch_id": {
          "type": "string"
        },
        "inputs": {
          "$ref": "#/$defs/jsonObject"
        },
        "result": {
          "$ref": "#/$defs/jsonValue"
        },
        "decisive": {
          "type": "boolean"
        },
        "selected_branch_id": {
          "type": "string"
        },
        "rejected_branch_id": {
          "type": "string"
        }
      }
    },
    "publishRelayFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relay_url", "reason"],
      "properties": {
        "relay_url": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "peelerOutcomeKind": {
      "enum": ["success", "decrypt_failed", "stale_epoch", "malformed", "other"]
    },
    "jsonScalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "jsonValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/jsonScalar"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "auditEventKind": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "recorder"],
          "properties": {
            "type": {
              "const": "recorder_started"
            },
            "recorder": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "previous_mode", "new_mode", "reason"],
          "properties": {
            "type": {
              "const": "audit_data_mode_changed"
            },
            "previous_mode": {
              "$ref": "#/$defs/auditDataMode"
            },
            "new_mode": {
              "$ref": "#/$defs/auditDataMode"
            },
            "reason": {
              "type": "string"
            },
            "recorder_restarted": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "source"],
          "properties": {
            "type": {
              "const": "source_context"
            },
            "source": {
              "$ref": "#/$defs/auditSourceContext"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "context"],
          "properties": {
            "type": {
              "const": "engine_context"
            },
            "context": {
              "$ref": "#/$defs/auditEngineContext"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "reason", "context"],
          "properties": {
            "type": {
              "const": "group_context"
            },
            "reason": {
              "type": "string"
            },
            "context": {
              "$ref": "#/$defs/auditGroupContext"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "serialization_failures", "write_failures", "flush_failures"],
          "properties": {
            "type": {
              "const": "recorder_health"
            },
            "serialization_failures": {
              "$ref": "#/$defs/u64"
            },
            "write_failures": {
              "$ref": "#/$defs/u64"
            },
            "flush_failures": {
              "$ref": "#/$defs/u64"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "action", "origin", "phase"],
          "properties": {
            "type": {
              "const": "human_action"
            },
            "action": {
              "type": "string"
            },
            "origin": {
              "type": "string"
            },
            "phase": {
              "type": "string"
            },
            "fields": {
              "$ref": "#/$defs/stringArray"
            },
            "component_ids": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/u16"
              }
            },
            "target_count": {
              "$ref": "#/$defs/u64"
            },
            "message_ids": {
              "$ref": "#/$defs/messageRefArray"
            },
            "from_epoch": {
              "$ref": "#/$defs/u64"
            },
            "to_epoch": {
              "$ref": "#/$defs/u64"
            },
            "error_kind": {
              "type": "string"
            },
            "detail": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "transport", "payload_len", "payload_digest"],
          "properties": {
            "type": {
              "const": "transport_received"
            },
            "msg_id": {
              "$ref": "#/$defs/messageId"
            },
            "transport": {
              "$ref": "#/$defs/transportWireEnvelope"
            },
            "payload_len": {
              "$ref": "#/$defs/u64"
            },
            "payload_digest": {
              "$ref": "#/$defs/digestHex"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "msg_id", "envelope_kind", "transport_source", "payload_len", "payload_digest"],
          "properties": {
            "type": {
              "const": "ingest_entry"
            },
            "msg_id": {
              "$ref": "#/$defs/messageId"
            },
            "envelope_kind": {
              "type": "string"
            },
            "transport_source": {
              "type": "string"
            },
            "transport": {
              "$ref": "#/$defs/transportWireEnvelope"
            },
            "payload_len": {
              "$ref": "#/$defs/u64"
            },
            "payload_digest": {
              "$ref": "#/$defs/digestHex"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "msg_id", "outcome_kind"],
          "properties": {
            "type": {
              "const": "ingest_outcome"
            },
            "msg_id": {
              "$ref": "#/$defs/messageId"
            },
            "outcome_kind": {
              "type": "string"
            },
            "stale_reason": {
              "type": "string"
            },
            "epoch": {
