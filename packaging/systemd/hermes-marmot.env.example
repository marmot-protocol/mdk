# Example EnvironmentFile for dm-agent.service and hermes-gateway.service.
# Keep this file mode 0640 and group-readable by the shared marmot-agent group.

MARMOT_HOME=/var/lib/marmot-agent
MARMOT_AGENT_SOCKET=/run/marmot-agent/dm-agent.sock
MARMOT_AGENT_AUTH_TOKEN_FILE=/etc/marmot-agent/control.token
MARMOT_AGENT_SOCKET_DIR_MODE=0770
MARMOT_AGENT_SOCKET_MODE=0660

# Public relays used by both the phone app and dm-agent.
MARMOT_RELAY_EU=wss://relay.eu.whitenoise.chat
MARMOT_RELAY_US=wss://relay.us.whitenoise.chat

# Set when dm-agent has more than one local agent account.
MARMOT_ACCOUNT_ID_HEX=

# Optional inbound filter and home-channel target for Hermes scheduled delivery.
MARMOT_GROUP_ID_HEX=
MARMOT_HOME_CHANNEL=

# Optional live-preview broker candidates. Durable Marmot sends work without this.
MARMOT_QUIC_CANDIDATES=quic://quic-broker.ipf.dev:4450

HERMES_HOME=/var/lib/hermes-agent
