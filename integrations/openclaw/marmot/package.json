{
  "name": "@marmot-protocol/openclaw-marmot",
  "version": "0.9.3",
  "description": "OpenClaw channel plugin for Marmot through the local wn-agent control socket",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.19.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "marmot",
      "label": "Marmot",
      "blurb": "End-to-end encrypted Marmot groups through the local wn-agent connector."
    }
  },
  "files": ["dist", "index.ts", "setup-entry.ts", "src", "openclaw.plugin.json", "manifest.json", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoketest": "node ./scripts/wn-agent-smoketest.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "openclaw": "2026.6.11",
    "typescript": "^5.6.0",
    "vite": "6.4.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "tar": "7.5.16",
      "vite": "6.4.3"
    }
  }
}
