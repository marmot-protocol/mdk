FROM rust:1.90-bookworm

ARG HERMES_AGENT_REPO_URL=https://github.com/NousResearch/hermes-agent.git
ARG HERMES_AGENT_REF=

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        libssl-dev \
        pkg-config \
        python3.11 \
        python3.11-dev \
        python3.11-venv \
        qrencode \
        tini \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 "$HERMES_AGENT_REPO_URL" /opt/hermes-agent \
    && if [ -n "$HERMES_AGENT_REF" ]; then \
        git -C /opt/hermes-agent fetch --depth 1 origin "$HERMES_AGENT_REF" || true; \
        git -C /opt/hermes-agent checkout "$HERMES_AGENT_REF"; \
    fi \
    && python3.11 -m venv /opt/hermes-agent/.venv \
    && /opt/hermes-agent/.venv/bin/python -m pip install --upgrade pip \
    && /opt/hermes-agent/.venv/bin/python -m pip install -e "/opt/hermes-agent[all,dev]"

WORKDIR /work/darkmatter
COPY . .

RUN cargo build --locked --release -p agent-connector --bin dm-agent \
    && install -m 0755 target/release/dm-agent /usr/local/bin/dm-agent \
    && install -m 0755 scripts/hermes_marmot_configure_gateway.py /usr/local/bin/marmot-configure-hermes-gateway \
    && install -m 0755 scripts/hermes_marmot_container_entrypoint.sh /usr/local/bin/hermes-marmot-entrypoint \
    && ln -sfn /opt/hermes-agent/.venv/bin/hermes /usr/local/bin/hermes

ENV MARMOT_HOME=/data/marmot-agent \
    HERMES_HOME=/data/hermes-home \
    MARMOT_AGENT_SOCKET=/run/marmot-agent/dm-agent.sock \
    MARMOT_AGENT_AUTH_TOKEN_FILE=/data/marmot-agent/control.token \
    MARMOT_AGENT_SOCKET_DIR_MODE=0770 \
    MARMOT_AGENT_SOCKET_MODE=0660 \
    MARMOT_RELAYS=wss://relay.eu.whitenoise.chat,wss://relay.us.whitenoise.chat \
    MARMOT_QUIC_CANDIDATES=quic://quic-broker.ipf.dev:4450 \
    HERMES_MARMOT_STREAMING=1 \
    HERMES_MARMOT_STREAMING_TRANSPORT=auto \
    HERMES_MARMOT_TOOL_PROGRESS=off \
    HERMES_MARMOT_INTERIM_MESSAGES=0 \
    HERMES_MARMOT_LONG_RUNNING_NOTIFICATIONS=0 \
    HERMES_MARMOT_BUSY_ACK_DETAIL=0 \
    PATH=/opt/hermes-agent/.venv/bin:/usr/local/cargo/bin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

VOLUME ["/data"]
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/hermes-marmot-entrypoint"]
